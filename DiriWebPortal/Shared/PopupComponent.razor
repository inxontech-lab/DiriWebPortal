<style>
    .popup-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: rgba(0, 0, 0, 0.5);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 10000;
    }

    .popup-content {
        background-color: white;
        padding: 2rem;
        border-radius: 10px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.3);
        max-width: 400px;
        width: 90%;
        animation: popup-fade-in 0.3s ease-out;
    }

</style>


@page "/publications1"




@* <button class="btn btn-primary" @onclick="ShowPopup">Open Popup</button> *@



    <div class="popup-overlay" @onclick="ClosePopup">
        <div class="popup-content" @onclick:stopPropagation>
            <h3>Hello from Popup</h3>
            <p>This is a Blazor modal popup.</p>
            <button class="btn btn-secondary" @onclick="ClosePopup">Close</button>
        </div>
    </div>


@code {
    private bool showPopup = false;

    void ShowPopup()
    {
        showPopup = true;
    }

    void ClosePopup()
    {
        showPopup = false;
    }
}