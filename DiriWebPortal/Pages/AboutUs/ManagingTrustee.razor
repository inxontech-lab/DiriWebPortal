@layout _CommonPageLayout

@page "/ManagingTrustee"

    <!-- breadcrumb-area start -->
  <div class="breadcrumb-area">
        <div class="container">
            <div class="row">
                <div class="breadcrumb_box text-center" style="margin-bottom:20px">
                    <ul class="breadcrumb-list">
                        <li class="breadcrumb-item"><a href="/">Home/</a>Founder & Trustee</li>
                    </ul>
                </div>
                @if (managingTrusteeInfo != null && designation != null)
                {
                    <div class="col-lg-9">
                        <div class="section-title">
                            <div class="team-info">
                                <h5 class="name">About Managing Trustee and Chairman</h5>
                                <div class="tab-content-inner mt-30">
                                @foreach(var lst in designation)
                                {
                                    <ul class="check-list">
                                        <li class="list-item">@lst.DesignationDetails</li>                                        
                                    </ul>
                                }
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3">
                        <div class="grid-item">
                            <div class="ht-team-member">
                                <div class="team-image">
                                    <img class="img-fluid" src="@managingTrusteeInfo.ManagingTrusteeImagePath" alt="">
                                    <div class="social-networks">
                                        <div class="inner">
                                            <p style="color:white">Managing Trustee & Chairman</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="team-info">
                                    <h5 class="name">@managingTrusteeInfo.ManagingTrusteeName</h5>
                                    <div class="position">Managing Trustee & Chairman</div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
    <!-- breadcrumb-area end -->


  <div class="site-wrapper-reveal">
            <!--======== Tabs Wrapper Start ======== -->
            <div class="tabs-wrapper  section-space--ptb_100">
                <div class="container">
                    <div class="row">
                        <div class="col-lg-12">
                            <div class="section-title-wrapper text-center section-space--mb_60 wow move-up">                                
                                <h3 class="section-title">List of the publications including <span class="text-color-primary">International Research Journal</span> and articles </h3>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-lg-12 ht-tab-wrap">
                            <div class="row">
                                <div class="col-12 text-center wow move-up ">
                                    <ul class="nav justify-content-center ht-tab-menu" role="tablist">
                                        <li class="tab__item nav-item active">
                                            <a class="nav-link active" id="nav-tab1" data-bs-toggle="tab" href="#author-tab" role="tab" aria-selected="true">Author</a>
                                        </li>
                                        <li class="tab__item nav-item">
                                            <a class="nav-link" id="nav-tab2" data-bs-toggle="tab" href="#publisher-tab" role="tab" aria-selected="false">Publisher</a>
                                        </li>
                                    </ul>
                                </div>
                            </div>

                            <div class="tab-content ht-tab__content wow move-up">
                                <div class="tab-pane fade show active" id="author-tab" role="tabpanel">
                                    <div class="tab-history-wrap">
                                        <div class="row">                                            
                                            <div class="col-lg-11 offset-lg-1 ">
                                                <div class="tab-content-inner mt-30">
                                                    @if (articles != null)
                                                    {
                                                        <ul class="check-list section-space--mb_40">
                                                            @foreach (var art in articles)
                                                            {
                                                                <li class="list-item">
                                                                    @art.ArticleName
                                                                    <br/>
                                                                    <a href="@art.ArticleLink">@art.ArticleLink</a>
                                                                </li>
                                                            }
                                                        </ul>
                                                    }   
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="publisher-tab" role="tabpanel">
                                    <div class="tab-history-wrap">
                                        <div class="row">                                           
                                            <div class="col-lg-11 offset-lg-1 ">
                                                <div class="tab-content-inner  mt-30">
                                                    @if (publications != null)
                                                    {
                                                        <ul class="check-list section-space--mb_40">
                                                            @foreach (var pub in publications)
                                                            {
                                                                <li class="list-item">
                                                                    @pub.PublicationName                                                                                                                                        
                                                                </li>
                                                            }
                                                        </ul>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!--======== Tabs Wrapper End ======== -->
        </div>


