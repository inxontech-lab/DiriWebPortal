@layout _CommonPageLayout

@page "/Ourvision"

<div class="breadcrumb-area">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="breadcrumb_box text-center" style="margin-bottom:20px">
                    <ul class="breadcrumb-list">
                        <li class="breadcrumb-item"><a href="/">Home/</a>Our Vision</li>
                    </ul>
                </div>
                <div class="row">
                    @if (aboutUsDetails != null)
                    {
                        <div class="col-lg-12">
                            <div class="section-title section-space--mb_60">
                                <div class="team-info ">
                                    <h5 class="name">Our Vision</h5>
                                    <p class="text mt-30" style="color:black"> @((MarkupString)aboutUsDetails.AboutUsDetails)</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {

}
