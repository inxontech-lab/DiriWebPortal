@layout _CommonPageLayout

@page "/publication-articles"



<div class="breadcrumb-area" style="height: 400px;">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="breadcrumb_box text-center" style="margin-bottom:20px">
                    <ul class="breadcrumb-list">
                        <li class="breadcrumb-item"><a href="/">Home/</a>About Maizbhandari Tarika</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-12">
                <div class="section-title section-space--mb_60 text-center">
                    <h1 class="breadcrumb-title text-color-primary">About Maizbhandari Tarika</h1>
                </div>
            </div>
        </div>
    </div>
</div>


@if (_lstPublicationsArticles != null)
{
    <div class="site-wrapper-reveal section-space--pt_100 section-space--pb_70" style="margin-top:-50px">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <!-- section-title-wrap Start -->
                    <div class="section-title-wrap text-start section-space--mb_15">
                        <h3 class="heading">Articles</h3>
                    </div>
                    <!-- section-title-wrap Start -->
                </div>
            </div>

            <div class="row">
                <div class="col-12">
                    <div class="projects-wrap swiper-container projects-slider__container">
                        <ol class="comment-list">
                            @foreach (var val in _lstPublicationsArticles)
                            {
                                <li class="comment border-bottom">
                                    <div class="meta">
                                        <h6 class="fn">
                                            @val.ArticleNameEn
                                        </h6>
                                    </div>
                                    @if (val.Attachments != null)
                                    {
                                        @foreach (var att in val.Attachments)
                                        {
                                            <div class="comment-text">
                                                <a href="@att.AttachmentLocation" target="_blank" rel="tag">
                                                    @att.AttachmentTitle
                                                </a>
                                            </div>
                                        }
                                    }
                                    
                                    <div class="comment-text">
                                        @if (val.DOI != null)
                                        {
                                            <p>
                                                DOI:
                                                <a href="@val.DOI" target="_blank" rel="tag">
                                                    @val.DOI
                                                </a>
                                            </p>
                                        }

                                    </div>

                                    <div class="comment-actions">
                                        <div class="comment-reply-link">
                                            @{
                                                int i = 1;
                                                string authors = "";
                                            }
                                            @if (val.Writers != null)
                                            {
                                                @foreach (var newVal in val.Writers)
                                                {
                                                    if (i == 1)
                                                    {
                                                        authors = newVal?.WriterNameEn;
                                                    }
                                                    else
                                                    {
                                                        authors = authors + ", " + newVal?.WriterNameEn;
                                                    }
                                                    i++;
                                                }
                                            }
                                            <p>@authors</p>
                                        </div>|
                                        <div class="comment-reply-link"> Language: @val.Language </div>|
                                        <div class="comment-reply-link"> Published: @val.PublishedDate?.ToString("MMMM d, yyyy")</div>
                                    </div>
                                </li>
                            }
                        </ol>
                    </div>
                    <div class="section-under-heading text-center section-space--mt_40">Back To <a href="/">Home</a></div>
                </div>
            </div>
        </div>
    </div>
}

