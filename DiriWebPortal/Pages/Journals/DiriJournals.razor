@layout _CommonPageLayout

@page "/DiriJournals"
@inject IJSRuntime JS



<div class="breadcrumb-area" style="height: 400px;">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="breadcrumb_box text-center" style="margin-bottom:20px">
                    <ul class="breadcrumb-list">
                        <li class="breadcrumb-item"><a href="/">Home/</a>DIRI Journals</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-12">
                <div class="section-title section-space--mb_60 text-center">
                      <h1 class="breadcrumb-title text-color-primary">DIRI Journals</h1>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- breadcrumb-area end -->
@* /@book.VolumeId *@

<div class="site-wrapper-reveal section-space--pt_100 section-space--pb_70" style="margin-top:-50px">
    <div class="container">
        @if (_lstJournal != null && _lstJournal.Count > 0)
        {
            @foreach (var i in Enumerable.Range(0, (_lstJournal.Count + 2) / 3))
            {
                <div class="row" style="margin-top:25px;">
                    <div class="col-12">
                        <div class="row ht-team-member-style-one">
                            @foreach (var book in _lstJournal.Skip(i * 3).Take(3))
                            {
                                <div class="col-lg-4 col-md-4 col-sm-6 mb-4">
                                    <a href="journal-details/@book.VolumeId" class="projects-wrap style-01 wow move-up">
                                        <div class="projects-image-box">
                                            <div class="projects-image">
                                                <img class="img-fluid" src="@book.Thumbnail" alt="">
                                            </div>
                                            <div class="content">
                                                <h6 class="heading">@book.JournalName</h6>
                                                <div class="post-categories">ISSN: @book.ISSN | Volume: @book.VolumeNumber Issue: @book.IssueNumber | @book.PublicationYear</div>
                                                <div class="text">
                                                    <i>@book.Description. @book.VolumeDescription.</i>
                                                </div>
                                                <div class="box-projects-arrow">
                                                    <span class="button-text">View Journal Issue</span>
                                                    <i class="fa fa-long-arrow-right ml-1"></i>
                                                </div>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        <div class="section-under-heading text-center section-space--mt_40">
            <a href="/publications">View DIRI Publications <i class="ml-1 button-icon far fa-long-arrow-right"></i></a>
        </div>
    </div>
</div>

@code {
    private async Task OpenPdf()
    {
        // Option 1: If PDF is in wwwroot
        var pdfPath = "/Journals/DIRI Journal.pdf";
        JS.InvokeVoidAsync("window.open", pdfPath, "_blank");
    }
}
