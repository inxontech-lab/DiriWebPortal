@inherits LayoutComponentBase

<RadzenComponents />

<RadzenLayout>
    <RadzenHeader>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem" class="rz-px-4 rz-py-2">
            <RadzenSidebarToggle Click="@(() => sidebarExpanded = !sidebarExpanded)" />
            <RadzenText TextStyle="TextStyle.H6">DiriWebAdmin</RadzenText>
        </RadzenStack>
    </RadzenHeader>

    <RadzenSidebar @bind-Expanded="sidebarExpanded" Style="width: 250px;">
        <NavMenu />
    </RadzenSidebar>

    <RadzenBody class="rz-p-4">
        @Body
    </RadzenBody>
</RadzenLayout>

@code {
    private bool sidebarExpanded = true;
}
