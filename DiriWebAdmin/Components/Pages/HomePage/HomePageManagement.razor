@page "/homepage"

<PageTitle>Home Page Management</PageTitle>

<div class="homepage-admin-page">
    <div class="homepage-admin-hero mb-4">
        <div>
            <h3 class="mb-2">Home Page Content Management</h3>
            <p class="mb-0">Manage the same data blocks rendered on the public <code>Index.razor</code> page: banner slides, numeric dashboard, about us, founder info, and managing trustee info.</p>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-6 col-xl-3">
            <div class="homepage-summary-card">
                <span class="summary-label">Banner Slides</span>
                <strong>@bannerTexts.Count</strong>
                <span class="summary-meta">Carousel records available</span>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="homepage-summary-card">
                <span class="summary-label">Numeric Dashboards</span>
                <strong>@numericDashboards.Count</strong>
                <span class="summary-meta">Counters for journals, research, universities, conferences</span>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="homepage-summary-card">
                <span class="summary-label">About Us</span>
                <strong>@aboutUsItems.Count</strong>
                <span class="summary-meta">Intro section records</span>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="homepage-summary-card">
                <span class="summary-label">Leadership Cards</span>
                <strong>@(founderInfos.Count + managingTrusteeInfos.Count)</strong>
                <span class="summary-meta">Founder and managing trustee records</span>
            </div>
        </div>
    </div>

    <RadzenTabs RenderMode="TabRenderMode.Client" class="homepage-tabs">
        <Tabs>
            <RadzenTabsItem Text="Banner Text">
                <div class="row g-3 mt-1">
                    <div class="col-lg-8">
                        <RadzenDataGrid class="homepage-grid" Data="bannerTexts" TItem="BannerText" AllowPaging="true" PageSize="8" AllowSorting="true" AllowFiltering="true">
                            <Columns>
                                <RadzenDataGridColumn TItem="BannerText" Property="Id" Title="Id" Width="70px" />
                                <RadzenDataGridColumn TItem="BannerText" Property="TitleText" Title="Title" />
                                <RadzenDataGridColumn TItem="BannerText" Property="Subtitle" Title="Subtitle" />
                                <RadzenDataGridColumn TItem="BannerText" Property="BannerImageLocation" Title="Image Path" />
                                <RadzenDataGridColumn TItem="BannerText" Title="Active" Width="90px">
                                    <Template Context="item">@(item.Active == 1 ? "Yes" : "No")</Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="BannerText" Title="Actions" Width="200px" TextAlign="TextAlign.Center">
                                    <Template Context="item">
                                        @if (!string.IsNullOrWhiteSpace(item.BannerImageLocation))
                                        {
                                            <a class="btn btn-sm homepage-action-view me-2"
                                               href="@ResolveImageUrl(item.BannerImageLocation)"
                                               target="_blank"
                                               rel="noopener noreferrer">
                                                <span class="rz-button-text">View</span>
                                            </a>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-sm homepage-action-view me-2" disabled>View</button>
                                        }
                                        <RadzenButton Icon="edit" Size="ButtonSize.Small" class="me-2 homepage-action-edit" Click="() => EditBannerText(item)" />
                                        <RadzenButton Icon="delete" Size="ButtonSize.Small" class="homepage-action-delete" Click="() => DeleteBannerTextAsync(item)" />
                                    </Template>
                                </RadzenDataGridColumn>
                            </Columns>
                        </RadzenDataGrid>
                    </div>
                    <div class="col-lg-4">
                        <EditForm Model="bannerForm" OnSubmit="SaveBannerTextAsync">
                            <div class="card homepage-form-card">
                                <div class="card-header">@(isBannerEditMode ? "Edit Banner Slide" : "Create Banner Slide")</div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <label class="form-label">Title Text</label>
                                        <InputTextArea class="form-control" @bind-Value="bannerForm.TitleText" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Subtitle</label>
                                        <InputTextArea class="form-control" @bind-Value="bannerForm.Subtitle" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Banner Image</label>
                                        <InputFile class="form-control" OnChange="HandleBannerImageSelected" accept="image/*" />
                                        <small class="form-text text-muted">Choose an image file instead of typing the path manually.</small>
                                        @if (!string.IsNullOrWhiteSpace(bannerForm.BannerImageLocation))
                                        {
                                            <div class="file-selection-note mt-2">Saved path: @bannerForm.BannerImageLocation</div>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(bannerForm.BannerImageLocation))
                                    {
                                        <div class="image-preview-shell mb-3">
                                            <img src="@ResolveImageUrl(bannerForm.BannerImageLocation)" alt="Banner preview" class="img-fluid rounded" />
                                        </div>
                                    }
                                    <div class="form-check mb-3">
                                        <InputCheckbox class="form-check-input" @bind-Value="bannerActiveValue" />
                                        <label class="form-check-label">Active</label>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <RadzenButton Icon="save" Text="Save" ButtonType="ButtonType.Submit" class="homepage-save-btn" />
                                        <button class="btn homepage-clear-btn" type="button" @onclick="ResetBannerForm">Clear</button>
                                    </div>
                                </div>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </RadzenTabsItem>

            <RadzenTabsItem Text="Numeric Dashboard">
                <div class="row g-3 mt-1">
                    <div class="col-lg-8">
                        <RadzenDataGrid class="homepage-grid" Data="numericDashboards" TItem="NumericDashboard" AllowPaging="true" PageSize="8" AllowSorting="true">
                            <Columns>
                                <RadzenDataGridColumn TItem="NumericDashboard" Property="Id" Title="Id" Width="70px" />
                                <RadzenDataGridColumn TItem="NumericDashboard" Property="TotalJournal" Title="Journals" />
                                <RadzenDataGridColumn TItem="NumericDashboard" Property="ResearchTittle" Title="Research Titles" />
                                <RadzenDataGridColumn TItem="NumericDashboard" Property="UniversityInvolved" Title="Universities" />
                                <RadzenDataGridColumn TItem="NumericDashboard" Property="Conference" Title="Conferences" />
                                <RadzenDataGridColumn TItem="NumericDashboard" Title="Active" Width="90px">
                                    <Template Context="item">@(item.Active == 1 ? "Yes" : "No")</Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="NumericDashboard" Title="Actions" Width="130px" TextAlign="TextAlign.Center">
                                    <Template Context="item">
                                        <RadzenButton Icon="edit" Size="ButtonSize.Small" class="me-2 homepage-action-edit" Click="() => EditNumericDashboard(item)" />
                                        <RadzenButton Icon="delete" Size="ButtonSize.Small" class="homepage-action-delete" Click="() => DeleteNumericDashboardAsync(item)" />
                                    </Template>
                                </RadzenDataGridColumn>
                            </Columns>
                        </RadzenDataGrid>
                    </div>
                    <div class="col-lg-4">
                        <EditForm Model="numericDashboardForm" OnSubmit="SaveNumericDashboardAsync">
                            <div class="card homepage-form-card">
                                <div class="card-header">@(isNumericDashboardEditMode ? "Edit Numeric Dashboard" : "Create Numeric Dashboard")</div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <label class="form-label">Journals Published</label>
                                        <InputNumber class="form-control" @bind-Value="numericDashboardForm.TotalJournal" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Research Titles</label>
                                        <InputNumber class="form-control" @bind-Value="numericDashboardForm.ResearchTittle" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Universities Involved</label>
                                        <InputNumber class="form-control" @bind-Value="numericDashboardForm.UniversityInvolved" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">International Conferences</label>
                                        <InputNumber class="form-control" @bind-Value="numericDashboardForm.Conference" />
                                    </div>
                                    <div class="form-check mb-3">
                                        <InputCheckbox class="form-check-input" @bind-Value="numericDashboardActiveValue" />
                                        <label class="form-check-label">Active</label>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <RadzenButton Icon="save" Text="Save" ButtonType="ButtonType.Submit" class="homepage-save-btn" />
                                        <button class="btn homepage-clear-btn" type="button" @onclick="ResetNumericDashboardForm">Clear</button>
                                    </div>
                                </div>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </RadzenTabsItem>

            <RadzenTabsItem Text="About Us">
                <div class="row g-3 mt-1">
                    <div class="col-lg-8">
                        <RadzenDataGrid class="homepage-grid" Data="aboutUsItems" TItem="AboutU" AllowPaging="true" PageSize="8" AllowSorting="true">
                            <Columns>
                                <RadzenDataGridColumn TItem="AboutU" Property="Id" Title="Id" Width="70px" />
                                <RadzenDataGridColumn TItem="AboutU" Property="AboutUsTitle" Title="Title" />
                                <RadzenDataGridColumn TItem="AboutU" Property="AbouUsText" Title="Description" />
                                <RadzenDataGridColumn TItem="AboutU" Title="Active" Width="90px">
                                    <Template Context="item">@(item.Active == 1 ? "Yes" : "No")</Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="AboutU" Title="Actions" Width="130px" TextAlign="TextAlign.Center">
                                    <Template Context="item">
                                        <RadzenButton Icon="edit" Size="ButtonSize.Small" class="me-2 homepage-action-edit" Click="() => EditAboutUs(item)" />
                                        <RadzenButton Icon="delete" Size="ButtonSize.Small" class="homepage-action-delete" Click="() => DeleteAboutUsAsync(item)" />
                                    </Template>
                                </RadzenDataGridColumn>
                            </Columns>
                        </RadzenDataGrid>
                    </div>
                    <div class="col-lg-4">
                        <EditForm Model="aboutUsForm" OnSubmit="SaveAboutUsAsync">
                            <div class="card homepage-form-card">
                                <div class="card-header">@(isAboutUsEditMode ? "Edit About Us" : "Create About Us")</div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <label class="form-label">Title</label>
                                        <InputText class="form-control" @bind-Value="aboutUsForm.AboutUsTitle" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Description</label>
                                        <InputTextArea class="form-control" @bind-Value="aboutUsForm.AbouUsText" />
                                    </div>
                                    <div class="form-check mb-3">
                                        <InputCheckbox class="form-check-input" @bind-Value="aboutUsActiveValue" />
                                        <label class="form-check-label">Active</label>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <RadzenButton Icon="save" Text="Save" ButtonType="ButtonType.Submit" class="homepage-save-btn" />
                                        <button class="btn homepage-clear-btn" type="button" @onclick="ResetAboutUsForm">Clear</button>
                                    </div>
                                </div>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </RadzenTabsItem>

            <RadzenTabsItem Text="Founder Info">
                <div class="homepage-single-form mt-3">
                    <EditForm Model="founderInfoForm" OnSubmit="SaveFounderInfoAsync">
                        <div class="card homepage-form-card homepage-form-shell">
                            <div class="card-header">@(isFounderInfoEditMode ? "Edit Founder Info" : "Create Founder Info")</div>
                            <div class="card-body">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Founder Name</label>
                                        <InputText class="form-control" @bind-Value="founderInfoForm.FounderName" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Image</label>
                                        <InputFile class="form-control" OnChange="HandleFounderImageSelected" accept="image/*" />
                                        @if (!string.IsNullOrWhiteSpace(founderInfoForm.FounderImagePath))
                                        {
                                            <div class="file-selection-note mt-2">Saved path: @founderInfoForm.FounderImagePath</div>
                                        }
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Title 1</label>
                                        <InputText class="form-control" @bind-Value="founderInfoForm.FounderTittle1" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Title 2</label>
                                        <InputText class="form-control" @bind-Value="founderInfoForm.FounderTittle2" />
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">Profile Message</label>
                                        <InputTextArea class="form-control" @bind-Value="founderInfoForm.FounderMessage" />
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">About Founder</label>
                                        <RadzenHtmlEditor @bind-Value="founderInfoForm.AboutFounder" class="homepage-html-editor" Style="height: 260px;" />
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(founderInfoForm.FounderImagePath))
                                    {
                                        <div class="col-12">
                                            <div class="image-preview-shell">
                                                <img src="@ResolveImageUrl(founderInfoForm.FounderImagePath)" alt="Founder preview" class="img-fluid rounded" />
                                            </div>
                                        </div>
                                    }
                                    <div class="col-12">
                                        <div class="form-check mb-3">
                                            <InputCheckbox class="form-check-input" @bind-Value="founderInfoActiveValue" />
                                            <label class="form-check-label">Active</label>
                                        </div>
                                        <div class="d-flex gap-2">
                                            <RadzenButton Icon="save" Text="Save" ButtonType="ButtonType.Submit" class="homepage-save-btn" />
                                            <button class="btn homepage-clear-btn" type="button" @onclick="ResetFounderInfoForm">Clear</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </EditForm>
                </div>
            </RadzenTabsItem>

            <RadzenTabsItem Text="Managing Trustee Info">
                <div class="homepage-single-form mt-3">
                    <EditForm Model="managingTrusteeInfoForm" OnSubmit="SaveManagingTrusteeInfoAsync">
                        <div class="card homepage-form-card homepage-form-shell">
                            <div class="card-header">@(isManagingTrusteeInfoEditMode ? "Edit Managing Trustee Info" : "Create Managing Trustee Info")</div>
                            <div class="card-body">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Managing Trustee Name</label>
                                        <InputText class="form-control" @bind-Value="managingTrusteeInfoForm.ManagingTrusteeName" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Image</label>
                                        <InputFile class="form-control" OnChange="HandleManagingTrusteeImageSelected" accept="image/*" />
                                        @if (!string.IsNullOrWhiteSpace(managingTrusteeInfoForm.ManagingTrusteeImagePath))
                                        {
                                            <div class="file-selection-note mt-2">Saved path: @managingTrusteeInfoForm.ManagingTrusteeImagePath</div>
                                        }
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Title 1</label>
                                        <InputText class="form-control" @bind-Value="managingTrusteeInfoForm.ManagingTrusteeNameTittle1" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Title 2</label>
                                        <InputText class="form-control" @bind-Value="managingTrusteeInfoForm.ManagingTrusteeNameTittle2" />
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">Profile Message</label>
                                        <InputTextArea class="form-control" @bind-Value="managingTrusteeInfoForm.ManagingTrusteeMessage" />
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">About Managing Trustee</label>
                                        <RadzenHtmlEditor @bind-Value="managingTrusteeInfoForm.AboutManagingTrustee" class="homepage-html-editor" Style="height: 260px;" />
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(managingTrusteeInfoForm.ManagingTrusteeImagePath))
                                    {
                                        <div class="col-12">
                                            <div class="image-preview-shell">
                                                <img src="@ResolveImageUrl(managingTrusteeInfoForm.ManagingTrusteeImagePath)" alt="Managing trustee preview" class="img-fluid rounded" />
                                            </div>
                                        </div>
                                    }
                                    <div class="col-12">
                                        <div class="form-check mb-3">
                                            <InputCheckbox class="form-check-input" @bind-Value="managingTrusteeInfoActiveValue" />
                                            <label class="form-check-label">Active</label>
                                        </div>
                                        <div class="d-flex gap-2">
                                            <RadzenButton Icon="save" Text="Save" ButtonType="ButtonType.Submit" class="homepage-save-btn" />
                                            <button class="btn homepage-clear-btn" type="button" @onclick="ResetManagingTrusteeInfoForm">Clear</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </EditForm>
                </div>
            </RadzenTabsItem>
        </Tabs>
    </RadzenTabs>
</div>
