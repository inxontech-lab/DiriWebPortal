@page "/home"

<PageTitle>Admin Home</PageTitle>

<div class="admin-home-page">
    <div class="admin-home-hero">
        <div>
            <span class="admin-home-badge">DIRI Web Admin</span>
            <h1>Administration Dashboard</h1>
            <p>
                Manage user accounts, roles, and portal content from a single secure workspace.
            </p>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="admin-home-card">
                <div class="admin-home-card-icon icon-users">👤</div>
                <h3>User Administration</h3>
                <p>Create users with hashed passwords and assign roles securely.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="admin-home-card">
                <div class="admin-home-card-icon icon-roles">🛡️</div>
                <h3>Role Management</h3>
                <p>Keep access levels organized with validated role CRUD operations.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="admin-home-card">
                <div class="admin-home-card-icon icon-content">✨</div>
                <h3>Content Updates</h3>
                <p>Publish homepage banners and portal details after signing in.</p>
            </div>
        </div>
    </div>
</div>
